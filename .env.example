# Telegram Bot API token from BotFather.
# Required when Telegram tools are implemented.
TELEGRAM_BOT_TOKEN=123456789:replace-with-your-bot-token

# Array allowlist of Telegram chat IDs or usernames.
# Examples: ["123456789", "-1001234567890", "@your_channel"]
TELEGRAM_ALLOWED_CHAT_IDS=[]

# Array blocklist of Telegram chat IDs or usernames.
TELEGRAM_BLOCKED_CHAT_IDS=[]

# Write-capable Telegram tool switches.
TELEGRAM_ENABLE_SEND_MESSAGES=false
TELEGRAM_ENABLE_FILE_DOWNLOADS=false

# Telegram safety limits.
TELEGRAM_MAX_MESSAGE_LENGTH=4096
TELEGRAM_MAX_FILE_SIZE_BYTES=5242880
TELEGRAM_REQUEST_TIMEOUT_SECONDS=30.0

# Simple tool-call rate limiting.
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60

# FastMCP server configuration.
MCP_SERVER_NAME=telegram-bot-mcp
MCP_TRANSPORT=streamable-http
MCP_HOST=127.0.0.1
MCP_PORT=51000
